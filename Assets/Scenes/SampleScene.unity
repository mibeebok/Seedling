  residents:
  - name: "\u0422\u0438\u043E\u043B\u0438"
    info: "\u041E\u0447\u0435\u043D\u044C \u0434\u0440\u0443\u0436\u0435\u043B\u044E\u0431\u043D\u044B\u0439
      \u0438 \u0436\u0438\u0437\u043D\u0435\u0440\u0430\u0434\u043E\u0441\u0442\u043D\u044B\u0439
      \u0437\u0430\u0439\u0447\u0438\u043A, \u0432\u0441\u0435\u0433\u0434\u0430
      \u0433\u043E\u0442\u043E\u0432\u044B\u0439 \u043F\u0440\u0438\u0439\u0442\u0438
      \u043D\u0430 \u043F\u043E\u043C\u043E\u0449\u044C \u043A \u0434\u0440\u0443\u0433\u0443."
    icon: {fileID: 2108580985, guid: 7468a3cfd0573914398233f02287c43f, type: 3}
  - name: "\u0418\u0445\u0432\u0438\u043B\u044C\u043D\u0438\u0445\u0442"
    info: "\u041E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A, \u043D\u0435\u043C\u043D\u043E\u0433\u043E\u0441\u043B\u043E\u0432\u0435\u043D
      \u0438 \u0445\u043C\u0443\u0440. \u041E\u0431\u044B\u0447\u043D\u043E \u043D\u0435
      \u043F\u043E\u0434\u043F\u0443\u0441\u043A\u0430\u0435\u0442 \u043A \u0441\u0435\u0431\u0435
      \u0431\u043B\u0438\u0437\u043A\u043E."
    icon: {fileID: 859756258, guid: a38cf4cd4936fa94e99ae44edc5c50cf, type: 3}
  - name: "\u0424\u0438\u043D\u043D\u0438\u043A"
    info: "\u0425\u0430\u0440\u0438\u0437\u043C\u0430\u0442\u0438\u0447\u043D\u044B\u0439,
      \u043D\u043E \u043A\u0440\u0430\u0439\u043D\u0435 \u043B\u0436\u0438\u0432\u044B\u0439
      \u0438 \u0445\u0438\u0442\u0440\u044B\u0439."
    icon: {fileID: -107471639, guid: c6723cc47db88d346bb726be5cb7c271, type: 3}
  - name: "\u0422\u0435\u0440\u0435\u043D\u0442\u0438\u0439"
    info: "\u0421\u0430\u043C\u044B\u0439 \u0441\u0442\u0430\u0440\u0448\u0438\u0439
      \u0436\u0438\u0442\u0435\u043B\u044C \u0434\u0435\u0440\u0435\u0432\u043D\u0438.
      \u041C\u0443\u0434\u0440\u044B\u0439 \u0438 \u043E\u0447\u0435\u043D\u044C
      \u043B\u044E\u0431\u0438\u0442 \u0434\u0435\u043D\u044C\u0433\u0438."
    icon: {fileID: 1444131057, guid: 2f624414dab5f1e47addd9541075950d, type: 3}
