    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u041D\u0430 \u0441\u0442\u0440\u0430\u043D\u0438\u0446\u0435 \"\u0416\u0438\u0442\u0435\u043B\u0438\"
    \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043D\u0430\u0439\u0442\u0438
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E \u043E \u0436\u0438\u0442\u0435\u043B\u044F\u0445
    \u0434\u0435\u0440\u0435\u0432\u043D\u0438 \"\u0420\u043E\u0441\u0442\u043E\u043A\".
    \u0416\u0438\u0442\u0435\u043B\u0438, \u0441 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
    \u0432\u044B \u0435\u0449\u0451 \u043D\u0435 \u0437\u043D\u0430\u043A\u043E\u043C\u044B,
    \u043F\u043E\u044F\u0432\u044F\u0442\u0441\u044F \u043F\u043E\u0441\u043B\u0435
    \u043F\u0435\u0440\u0432\u043E\u0439 \u0432\u0441\u0442\u0440\u0435\u0447\u0438."
