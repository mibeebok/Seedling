    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0423 \u0442\u0435\u0431\u044F \u043F\u043E\u044F\u0432\u0438\u043B\u043E\u0441\u044C
    \u043D\u043E\u0432\u043E\u0435 \u0437\u0430\u0434\u0430\u043D\u0438\u0435.\r\n\u0427\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0435\u0433\u043E,
    \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E \u0437\u0430\u0439\u0442\u0438
    \u0432 \"\u041A\u043D\u0438\u0433\u0443 \u0413\u0440\u0438\u0448\u0438\".\r\n\u0422\u0430\u043C
    \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C \u043E\u0442\u0441\u043B\u0435\u0436\u0438\u0432\u0430\u0442\u044C
    \u0432\u0441\u0435 \u0441\u0432\u043E\u0438 \u0437\u0430\u0434\u0430\u043D\u0438\u044F,
    \u0430 \u0442\u0430\u043A\u0436\u0435 \u0438 \u0434\u0440\u0443\u0433\u0443\u044E
    \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E \u043F\u043E \u0438\u0433\u0440\u0435."
